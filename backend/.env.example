# Application
APP_NAME="RollCall API"
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# Security
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# Face Recognition Authentication - Camera Client
BASE_URL=http://localhost:8000/api/v1
API_USER=admin@rollcall.com
API_PASSWORD=

# Database - PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=

# Face Recognition
FACE_MODEL_NAME=ArcFace
FACE_DETECTOR_BACKEND=retinaface
FACE_DISTANCE_THRESHOLD=0.40
FACE_REGISTRATION_SAMPLES=5

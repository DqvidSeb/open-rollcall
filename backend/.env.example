# Application
APP_NAME="RollCall API"
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# Security
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# Face Recognition Authentication - Camera Client
BASE_URL=http://localhost:8000/api/v1
API_USER=
API_PASSWORD=

# Database - PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=

# Face Recognition
FACE_MODEL_NAME=ArcFace
# Detector usado por el SERVIDOR para frames sin pre-recortar (clientes web).
# "yunet" = rapido y preciso en CPU (mismo detector que usa camera_client.py).
# El cliente de camara envia pre_cropped=true y omite esta deteccion.
FACE_DETECTOR_BACKEND=yunet
# Umbral de distancia coseno para ArcFace (DeepFace recomienda 0.68).
# 0.40 = muy estricto | 0.55 = equilibrado | 0.68 = permisivo.
FACE_DISTANCE_THRESHOLD=0.55
FACE_REGISTRATION_SAMPLES=5
